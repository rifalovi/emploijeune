# ===========================================================================
# Plateforme OIF Emploi Jeunes — variables d'environnement
# ---------------------------------------------------------------------------
# Copier ce fichier en `.env.local` et remplir avec les valeurs réelles.
# NE JAMAIS commiter `.env.local` — il est gitignoré.
# ===========================================================================

# --- Supabase (projet Europe) -----------------------------------------------
# URL publique du projet Supabase
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"

# Clé anon publique (safe côté navigateur, protégée par RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Clé service_role (NE JAMAIS exposer côté navigateur) — utilisée uniquement
# par les routes API Next.js et les scripts admin/seed
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ID de projet Supabase (utilisé par la CLI `supabase gen types`)
SUPABASE_PROJECT_ID="xxxxxxxxxxxx"

# --- Application ------------------------------------------------------------
# URL publique de l'application (utile pour les liens magic-link et les exports)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Nom affiché de l'application
NEXT_PUBLIC_APP_NAME="OIF — Suivi Emploi Jeunes"

# Adresse email d'expédition (magic-link, relances enquêtes)
APP_MAIL_FROM="scs@oif.example.org"

# --- Resend (envoi emails — Étape 6.5d) -------------------------------------
# Compte Resend Free (3000 emails/mois). Cf. docs/configuration/resend-setup.md
# pour la procédure complète (création compte, vérification domaine, DNS).
#
# Domaine V1 : suivi-projet.org (transitoire, propriété personnelle Carlos)
# Domaine V1.5/V2 : à migrer vers domaine OIF officiel quand DSI met à dispo
RESEND_API_KEY="re_xxxxxxxxxxxxx"
RESEND_DOMAIN="suivi-projet.org"
RESEND_FROM_EMAIL="noreply@suivi-projet.org"
RESEND_FROM_NAME="Plateforme OIF Emploi Jeunes"

# --- Sécurité ---------------------------------------------------------------
# Secret interne pour la signature de liens publics (enquêtes bénéficiaires)
# Générer avec : openssl rand -hex 32
APP_LINK_SIGNING_SECRET=""

# --- Observabilité (facultatif V1) ------------------------------------------
# Sentry DSN pour remontée d'erreurs côté serveur
SENTRY_DSN=""

# --- Environnement ----------------------------------------------------------
# `development`, `staging`, `production`
NEXT_PUBLIC_APP_ENV="development"
